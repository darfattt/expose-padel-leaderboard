# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Super-admin password (server-side check). Works for uploading to any club and
# is required to register new clubs. Each club also has its own admin password
# (set when the club is registered) that uploads events for that club only.
UPLOAD_PASSWORD=change-me

# LLM player reports — Groq (free, OpenAI-compatible). Get a key at https://console.groq.com/keys
GROQ_API_KEY=gsk_...
# Optional model override (defaults to llama-3.3-70b-versatile)
REPORT_MODEL=llama-3.3-70b-versatile
# Set to "false" to disable LLM report generation entirely
REPORTS_ENABLED=true
